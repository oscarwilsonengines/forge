# Telegram bot (optional — for mobile access)
FORGE_TELEGRAM_TOKEN=your-telegram-bot-token
FORGE_TELEGRAM_CHAT=your-chat-id

# GitHub (optional — gh CLI uses its own auth)
# GITHUB_TOKEN=ghp_xxxx

# Slack/Discord webhooks (optional)
# FORGE_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# FORGE_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
